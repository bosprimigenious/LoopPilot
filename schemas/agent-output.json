{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loop-pilot.local/schemas/agent-output.json",
  "title": "AgentOutput",
  "type": "object",
  "required": ["agent_id", "status", "summary"],
  "properties": {
    "schema_version": {"type": "string"},
    "agent_id": {"type": "string"},
    "status": {"type": "string", "enum": ["success", "insufficient_context", "refused", "error"]},
    "summary": {"type": "string"},
    "claims": {"type": "array"},
    "proposed_actions": {"type": "array"},
    "produced_artifacts": {"type": "array"},
    "uncertainties": {"type": "array"}
  },
  "additionalProperties": false
}
