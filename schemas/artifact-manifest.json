{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loop-pilot.local/schemas/artifact-manifest.json",
  "title": "ArtifactManifest",
  "type": "object",
  "required": ["schema_version", "run_id", "artifacts"],
  "properties": {
    "schema_version": {"type": "string"},
    "run_id": {"type": "string"},
    "loop_type": {"type": "string"},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string"},
          "sha256": {"type": "string"},
          "kind": {"type": "string"},
          "human_readable": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "terminal_outcome": {"type": ["string", "null"]},
    "created_at": {"type": "string"}
  },
  "additionalProperties": false
}
