{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loop-pilot.local/schemas/gate_result.schema.json",
  "title": "GateResult",
  "type": "object",
  "required": ["schema_version", "run_id", "gate", "evaluated_at"],
  "properties": {
    "schema_version": {"type": "string"},
    "run_id": {"type": "string"},
    "gate": {
      "type": "string",
      "enum": ["pass", "needs_review", "blocked"]
    },
    "evaluator": {"type": "string"},
    "evaluator_version": {"type": "string"},
    "profile": {"type": "string"},
    "evaluated_at": {"type": "string", "format": "date-time"},
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "status"],
        "properties": {
          "check_id": {"type": "string"},
          "status": {"type": "string", "enum": ["pass", "fail", "not_run", "not_configured"]},
          "message": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "blocking_findings": {"type": "array"},
    "non_blocking_findings": {"type": "array"},
    "recommended_review_action": {"type": "string"},
    "artifact_refs": {"type": "object"}
  },
  "additionalProperties": true
}
