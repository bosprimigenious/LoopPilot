page {
  background: #f6f8fb;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 28rpx;
}

.eyebrow {
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
  margin-bottom: 8rpx;
}

.title {
  color: #0f172a;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.15;
}

.subtitle {
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.5;
  margin-top: 10rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #dbe3ef;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.panel-title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.metric-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(3, 1fr);
}

.metric {
  background: #eef6f5;
  border: 1rpx solid #cfe3df;
  border-radius: 8rpx;
  padding: 20rpx 12rpx;
  text-align: center;
}

.metric-value {
  color: #0f766e;
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.1;
}

.metric-label {
  color: #425466;
  display: block;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.item {
  border-top: 1rpx solid #e5ebf3;
  padding: 20rpx 0;
}

.item:first-child {
  border-top: 0;
  padding-top: 0;
}

.item:last-child {
  padding-bottom: 0;
}

.item-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.item-meta {
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.45;
  margin-top: 8rpx;
}

.badge {
  border-radius: 999rpx;
  display: inline-flex;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1;
  padding: 8rpx 12rpx;
}

.badge-pass {
  background: #dcfce7;
  color: #166534;
}

.badge-review {
  background: #fef3c7;
  color: #92400e;
}

.badge-blocked {
  background: #fee2e2;
  color: #991b1b;
}

.badge-neutral {
  background: #e2e8f0;
  color: #334155;
}

.button-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.button {
  background: #0f766e;
  border-radius: 8rpx;
  color: #ffffff;
  flex: 1;
  font-size: 26rpx;
  line-height: 76rpx;
}

.button-secondary {
  background: #334155;
}

.field-label {
  color: #334155;
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.input {
  background: #ffffff;
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  box-sizing: border-box;
  height: 76rpx;
  padding: 0 18rpx;
  width: 100%;
}

.empty {
  color: #64748b;
  font-size: 25rpx;
  padding: 24rpx 0;
  text-align: center;
}

.notice {
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
  border-radius: 8rpx;
  color: #9a3412;
  font-size: 24rpx;
  line-height: 1.45;
  margin-bottom: 24rpx;
  padding: 18rpx 20rpx;
}
