<view class="page">
  <view class="header">
    <view class="eyebrow">Run</view>
    <view class="title">运行详情</view>
  </view>

  <view wx:if="{{connection.source && connection.source !== 'live'}}" class="notice">
    {{connection.useMock ? "Mock 数据模式" : "Live API 不可用，已回退 Mock 数据"}}
    <text wx:if="{{connection.error}}"> · {{connection.error}}</text>
  </view>

  <view wx:if="{{error}}" class="notice">{{error}}</view>

  <view wx:if="{{run}}" class="panel">
    <view class="row">
      <view class="item-title">{{run.title}}</view>
      <text class="badge {{run.badgeClass}}">{{run.outcome}}</text>
    </view>
    <view class="item-meta">{{run.runId}}</view>

    <view class="detail-list">
      <block wx:for="{{run.rows}}" wx:key="label">
        <view class="detail-row">
          <text class="detail-label">{{item.label}}</text>
          <text class="detail-value">{{item.value}}</text>
        </view>
      </block>
    </view>

    <view wx:if="{{run.terminalReason}}" class="reason">{{run.terminalReason}}</view>

    <view class="button-row">
      <button class="button button-secondary" data-value="{{run.runId}}" bindtap="copyValue">复制 Run ID</button>
      <button wx:if="{{run.reportPath}}" class="button" data-value="{{run.reportPath}}" bindtap="copyValue">复制报告路径</button>
    </view>
  </view>

  <view wx:if="{{run && run.artifacts.length}}" class="panel">
    <view class="panel-title">产物预览</view>
    <block wx:for="{{run.artifacts}}" wx:key="artifactId">
      <view class="artifact-item">
        <view class="row">
          <view class="artifact-kind">{{item.kind}}</view>
          <text class="badge {{item.readableBadgeClass}}">{{item.readableLabel}}</text>
        </view>
        <view class="artifact-path">{{item.path}}</view>
        <view wx:if="{{item.meta}}" class="item-meta">{{item.meta}}</view>
        <view class="button-row artifact-actions">
          <button class="button button-secondary" data-value="{{item.copyValue}}" catchtap="copyValue">复制路径</button>
        </view>
      </view>
    </block>
  </view>
</view>
