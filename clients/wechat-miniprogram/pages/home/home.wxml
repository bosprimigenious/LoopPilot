<view class="page">
  <view class="header">
    <view class="eyebrow">LoopPilot</view>
    <view class="title">今日闭环</view>
    <view class="subtitle">{{summary.date || ""}}</view>
  </view>

  <view wx:if="{{connection.source && connection.source !== 'live'}}" class="notice">
    {{connection.useMock ? "Mock 数据模式" : "Live API 不可用，已回退 Mock 数据"}}
    <text wx:if="{{connection.error}}"> · {{connection.error}}</text>
  </view>

  <view class="panel">
    <view class="metric-grid">
      <view class="metric">
        <text class="metric-value">{{summary.plannedCount || 0}}</text>
        <text class="metric-label">计划</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{summary.pendingReviewCount || 0}}</text>
        <text class="metric-label">审阅</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{summary.blockedCount || 0}}</text>
        <text class="metric-label">阻塞</text>
      </view>
    </view>
    <view class="outcome-strip">
      <text>成功 {{summary.outcomeCounts.succeeded || 0}}</text>
      <text>部分 {{summary.outcomeCounts.partial || 0}}</text>
      <text>失败 {{summary.outcomeCounts.failed || 0}}</text>
    </view>
    <view class="button-row">
      <button class="button" bindtap="openRuns">运行记录</button>
      <button class="button button-secondary" bindtap="openReview">审阅队列</button>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">最近运行</view>
    <block wx:if="{{latestRuns.length}}">
      <block wx:for="{{latestRuns}}" wx:key="runId">
        <view class="item item-link" data-run-id="{{item.runId}}" bindtap="openRunDetail">
          <view class="row">
            <view class="item-title">{{item.title}}</view>
            <text class="badge {{item.badgeClass}}">{{item.outcome}}</text>
          </view>
          <view class="item-meta">{{item.loopType}} · {{item.phase}} · {{item.updatedAt}}</view>
        </view>
      </block>
    </block>
    <view wx:else class="empty">暂无运行记录</view>
  </view>

  <view class="panel">
    <view class="panel-title">待审阅</view>
    <block wx:if="{{needsReview.length}}">
      <block wx:for="{{needsReview}}" wx:key="runId">
        <view class="item item-link" data-run-id="{{item.runId}}" bindtap="openReviewDetail">
          <view class="row">
            <view class="item-title">{{item.title}}</view>
            <text class="badge badge-review">{{item.status}}</text>
          </view>
          <view class="item-meta">{{item.loopType}} · {{item.runId}}</view>
        </view>
      </block>
    </block>
    <view wx:else class="empty">暂无待审阅事项</view>
  </view>
</view>
