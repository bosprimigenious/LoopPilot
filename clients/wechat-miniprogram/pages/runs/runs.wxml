<view class="page">
  <view class="header">
    <view class="eyebrow">Runs</view>
    <view class="title">运行记录</view>
  </view>

  <view wx:if="{{connection.source && connection.source !== 'live'}}" class="notice">
    {{connection.useMock ? "Mock 数据模式" : "Live API 不可用，已回退 Mock 数据"}}
    <text wx:if="{{connection.error}}"> · {{connection.error}}</text>
  </view>

  <view class="panel">
    <block wx:if="{{runs.length}}">
      <block wx:for="{{runs}}" wx:key="runId">
        <view class="item item-link" data-run-id="{{item.runId}}" bindtap="openRun">
          <view class="row">
            <view class="item-title">{{item.title}}</view>
            <text class="badge {{item.badgeClass}}">{{item.outcome}}</text>
          </view>
          <view class="item-meta">{{item.loopType}} · {{item.phase}}</view>
          <view class="item-meta">{{item.runId}}</view>
        </view>
      </block>
    </block>
    <view wx:else class="empty">暂无运行记录</view>
  </view>
</view>
