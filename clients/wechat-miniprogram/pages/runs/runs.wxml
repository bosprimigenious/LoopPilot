<view class="page">
  <view class="header">
    <view class="eyebrow">Runs</view>
    <view class="title">运行记录</view>
  </view>

  <view class="panel">
    <block wx:if="{{runs.length}}">
      <block wx:for="{{runs}}" wx:key="runId">
        <view class="item">
          <view class="row">
            <view class="item-title">{{item.title}}</view>
            <text class="badge {{item.badgeClass}}">{{item.outcome}}</text>
          </view>
          <view class="item-meta">{{item.loopType}} · {{item.phase}}</view>
          <view class="item-meta">{{item.runId}}</view>
        </view>
      </block>
    </block>
    <view wx:else class="empty">暂无运行记录</view>
  </view>
</view>
